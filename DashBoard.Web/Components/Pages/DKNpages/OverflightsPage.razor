@page "/overflight"
<PageTitle>@Departs.overflights</PageTitle>
<MudGrid>
    <MudItem xs="12" sm="6">
        <MudText >@ResForBodyPage.tokens</MudText>
        <MudChart T="double" ChartType="ChartType.Donut" LegendPosition="Position.Bottom" Width="100%" Height="300px"
                  ChartSeries="@([data])" ChartLabels="@labels">
        </MudChart>
    </MudItem>
    <MudItem xs="12" sm="6">
        <MudText>@ResForBodyPage.viols_month</MudText>
        <MudChart ChartType="ChartType.Donut" Width="100%" Height="300px" ChartSeries="@Data.AsChartDataSet()" ChartLabels="@Labels">
            <CustomGraphics>
                <text class="mud-donut-text mud-typography-h3" x="50%" y="50%">@Data.Sum()</text>
            </CustomGraphics>
        </MudChart>
    </MudItem>
    <MudItem xs="12">
        <MudText>@ResForBodyPage.viols</MudText>
<MudChart ChartType="ChartType.Bar" ChartSeries="@Series" ChartLabels="@XAxisLabels" Width="100%" Height="350px">
</MudChart>
    </MudItem>
</MudGrid>
@code {
    private static readonly int[] Data = [25, 77, 28, 5];
    private static readonly string[] Labels = ["Oil", "Coal", "Gas", "Biomass"];
 public List<ChartSeries<double>> Series = new()
    {
        new() { Name = "United States", Data = new double[] { 40, 20, 25, 27, 46, 60, 48, 80, 15 } },
        new() { Name = "Germany", Data = new double[] { 19, 24, 35, 13, 28, 15, 13, 16, 31 } },
        new() { Name = "Sweden", Data = new double[] { 8, 6, 11, 13, 4, 16, 10, 16, 18 } },
    };
    public string[] XAxisLabels = { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep" };

    public double[] data = { 25, 77, 28, 5 };
    public string[] labels = { "Oil", "Coal", "Gas", "Biomass" };
}