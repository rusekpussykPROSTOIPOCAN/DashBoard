@page "/AnalyticHome"
@using System.Net.Http.Json
@inject IDialogService DialogService
@inject Services.ApiService api
<MudContainer Fixed="true" MaxWidth="MaxWidth.Large">

    <MudGrid>

        <MudItem sm="6" md="6">
           <DialogPer OnChange="OnPeriodChanged"/>
        </MudItem>

       
        <MudItem md="6" sm="6"
                 Class="d-flex justify-sm-end justify-center pr-sm-4">
            <MudFab Href="/FormAnalityc"
                Color="Color.Success"
                    StartIcon="@Icons.Material.Filled.AddCircle"
                    Size="Size.Large"
                    Class="my-1" />
        </MudItem>

        <MudItem sm="3" xs="6">
            <MudText>Всего: <b>@(_data?.DailyStats?.Sum(x => x.AllPerimeter) ?? 0)</b></MudText>

        </MudItem>
        <MudItem sm="3" xs="6">
            <MudText>Выполнено: <b>@(_data?.DailyStats?.Sum(x => x.CompletePerimeter) ?? 0)</b></MudText>
           

        </MudItem>
        <MudItem sm="3" xs="6">
            <MudText>В работе: <b>@(_data?.DailyStats?.Sum(x => x.RemainedPerimeter) ?? 0)</b></MudText>

        </MudItem>
        <MudItem sm="3" xs="6">
            

        </MudItem>
        <MudItem xs="12" md="9">
          
            <MudDataGrid T="ViolationDto"
                         Filterable="true"
                         Items="@Violations"
                         ColumnResizeMode="ResizeMode.Column">
    
                <Columns>
                    <PropertyColumn Property="x => x.Article" Title="Статья" />
                    <PropertyColumn Property="x => x.ObjectAWeek" Title="Количество нарушений" />
                    <PropertyColumn Property="x => x.NewViolations" Title="Новые нарушения" />
                    <PropertyColumn Property="x => x.OldViolations" Title="Ранее учтенные" />
                </Columns>

            </MudDataGrid>
          
        </MudItem>

        <MudItem xs="12" md="3">
          
                <MudChart ChartType="ChartType.Pie"
                          ChartSeries="@ChartData.AsChartDataSet()"
                          
                          ChartLabels="@ChartLabels"
                          Width="100%"
                          Height="300px" />
           
        </MudItem>
       


    </MudGrid>
</MudContainer>

@code {
    private double[] ChartData => _data?.PerimeterBySource?.Select(x => (double)x.Sum).ToArray() ?? Array.Empty<double>();
    private string[] ChartLabels => _data?.PerimeterBySource?.Select(x =>x.Source).ToArray() ?? Array.Empty<string>();
    private List<ViolationDto> Violations = new();
    
    private int? _year;
    private int? _quarter;
    private int? _month;
    private AnaliticPageDTO? _data;
    private async Task OnPeriodChanged(DialogPer.Periods periods)
    {
        _year = periods.Year;
        _month = periods.Month;
        _quarter = periods.Quarter;
        await LoadData();
    }
    private async Task LoadData()
    {
        var query = new List<string>();

        if (_year.HasValue) query.Add($"year={_year}");
        if (_month.HasValue) query.Add($"month={_month}");
        if (_quarter.HasValue) query.Add($"quarter={_quarter}");

        var url = "api/getTableAnalitic";

        if (query.Any())
            url += "?" + string.Join("&", query);

        var result = await api.GetAsync<AnaliticPageDTO>(url);

        _data = result;

        Violations = _data?.Violations ?? new List<ViolationDto>();

        StateHasChanged();
    }
    protected override async Task OnInitializedAsync()
    {

        await LoadData();
    
    }

    
};

   

   