<MudButton Variant="Variant.Filled" OnClick="ToggleFilter">
    Выбрать период
</MudButton>
<MudPopover Open="_open" AnchorOrigin="Origin.BottomCenter">
<MudPaper Class="pa-4">

        <MudSelect T="int?" Label="@ResForBodyPage.Year" @bind-Value="_year">
        <MudSelectItem T="int?" Value="@((int?)null)">Все</MudSelectItem>
        <MudSelectItem T="int?" Value="2026">2026</MudSelectItem>
        <MudSelectItem T="int?" Value="2025">2025</MudSelectItem>
        </MudSelect>
        <MudSelect T="int?" Label="@ResForBodyPage.Qartal" @bind-Value="_quarter">
            <MudSelectItem T="int?" Value="@((int?)null)">Все</MudSelectItem>
            <MudSelectItem T="int?" Value="1">1</MudSelectItem>
            <MudSelectItem T="int?" Value="2">2</MudSelectItem>
            <MudSelectItem T="int?" Value="3">3</MudSelectItem>
            <MudSelectItem T="int?" Value="4">4</MudSelectItem>
        </MudSelect>
        <MudSelect T="int?" Label="@ResForBodyPage.Month" @bind-Value="_month">
           
        <MudSelectItem T="int?" Value="@((int?)null)">Все</MudSelectItem>
        <MudSelectItem T="int?" Value="1">1</MudSelectItem>
        <MudSelectItem T="int?" Value="2">2</MudSelectItem>
        <MudSelectItem T="int?" Value="3">3</MudSelectItem>
        <MudSelectItem T="int?" Value="4">4</MudSelectItem>
        <MudSelectItem T="int?" Value="5">5</MudSelectItem>
        <MudSelectItem T="int?" Value="6">6</MudSelectItem>
        <MudSelectItem T="int?" Value="7">7</MudSelectItem>
        <MudSelectItem T="int?" Value="8">8</MudSelectItem>
        <MudSelectItem T="int?" Value="9">9</MudSelectItem>
        <MudSelectItem T="int?" Value="10">10</MudSelectItem>
        <MudSelectItem T="int?" Value="11">11</MudSelectItem>
        <MudSelectItem T="int?" Value="12">12</MudSelectItem>
           
        </MudSelect>
        <MudButton OnClick="Submit">Применить</MudButton>
</MudPaper>

</MudPopover>
 
    
       
   
@code {
    private bool _open;
    private void ToggleFilter()
    {
        _open = true;
    }
   
    private int? _year;
    private int? _quarter;
    private int? _month;
    public class Periods
    {
        public int? Year { get; set; }
        public int? Quarter { get; set; }
        public int? Month { get; set; }
    }

    [Parameter]
    public EventCallback<Periods> OnChange{ get; set; }

    private async Task Submit()
    {
        var result = new Periods
        {
            Year = _year,
            Quarter = _quarter,
            Month = _month
        };
        _open = false; 
        
        await OnChange.InvokeAsync(result);

    }



    private async Task OnKeyDownAsync(KeyboardEventArgs args)
    {
        if (args.Key is "Enter" or "NumpadEnter")
        {
            await Submit();
        }
    }
 
   
    

   
}